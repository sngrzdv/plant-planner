# Supabase (обязательно)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Прокси: на Vercel включается автоматически (работает в РФ без VPN).
# Локально — прямое подключение. Принудительно: VITE_SUPABASE_PROXY_URL=/supabase
# Отключить proxy: VITE_SUPABASE_PROXY_URL=off

# OpenWeatherMap — погода на главной (опционально)
VITE_OPENWEATHER_API_KEY=

# Скриншоты для документации / ИИ (npm run screenshots) — не коммитить реальные значения
# DEMO_EMAIL=
# DEMO_PASSWORD=
# SCREENSHOT_BASE_URL=https://plant-planner-nu.vercel.app
